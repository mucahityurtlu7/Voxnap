{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voxnap",
  "version": "0.1.0",
  "identifier": "app.voxnap.mobile",
  "build": {
    "beforeDevCommand": "pnpm --filter @voxnap/mobile dev",
    "beforeBuildCommand": "pnpm --filter @voxnap/mobile build",
    "devUrl": "http://localhost:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Live whisper.cpp transcription.",
    "longDescription": "Voxnap mobile — privacy-first live transcription on iOS and Android."
  },
  "plugins": {}
}
