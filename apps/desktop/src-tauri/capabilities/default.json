{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Voxnap desktop window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "dialog:default",
    "fs:default",
    "log:default",
    "os:default",
    "shell:allow-open",
    "store:default"
  ]
}
