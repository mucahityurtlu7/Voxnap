{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voxnap",
  "version": "0.1.0",
  "identifier": "app.voxnap.desktop",
  "build": {
    "beforeDevCommand": "pnpm exec vite",
    "beforeBuildCommand": "pnpm exec vite build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Voxnap",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../models": "models"
    },
    "category": "Productivity",
    "shortDescription": "Live whisper.cpp transcription.",
    "longDescription": "Voxnap is a privacy-first live transcription app powered by whisper.cpp."
  },
  "plugins": {}
}
